# Optional: public certificate verification from any device (Supabase Storage).
# Create a public bucket named "certificates" (or set VITE_SUPABASE_CERTIFICATES_BUCKET).
# Add policies: allow public read; allow insert for anon only if you accept admin-key-in-browser tradeoff,
# or gate uploads behind Supabase Auth / Edge Functions.
#
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
# VITE_SUPABASE_CERTIFICATES_BUCKET=certificates

# Optional: base URL for QR codes when not in browser (e.g. SSR); otherwise window.location.origin is used.
# VITE_APP_BASE_URL=https://trizenventures.com
